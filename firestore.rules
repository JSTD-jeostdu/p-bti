rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────
    // submissions 컬렉션
    // 학생이 결과를 제출하는 컬렉션입니다.
    // ──────────────────────────────────────────
    match /submissions/{docId} {

      // 읽기: 허용 (교사 대시보드 onSnapshot 용)
      // 필요 시 교사 익명 인증 + 읽기 제한으로 강화 가능
      allow read: if true;

      // 생성(create): 허용 — 단, 필드·값 범위 엄격히 검증
      allow create: if
        // 정확히 5개 필드만 허용 (classId, school, truth, life, createdAt)
        request.resource.data.keys().toSet() == ['classId','school','truth','life','createdAt'].toSet()

        // classId: 문자열, "1"~"9" 또는 "unknown" / "manual"
        && request.resource.data.classId is string
        && request.resource.data.classId.size() <= 16

        // school: 4개 학파 값 중 하나
        && request.resource.data.school in ['sophist','socrates','confucian','daoist']

        // truth: 정수, 문항 가중치 범위 -20~+20
        && request.resource.data.truth is int
        && request.resource.data.truth >= -20
        && request.resource.data.truth <= 20

        // life: 정수, 문항 가중치 범위 -20~+20
        && request.resource.data.life is int
        && request.resource.data.life >= -20
        && request.resource.data.life <= 20

        // createdAt: 서버 타임스탬프만 허용 (클라이언트 위조 차단)
        && request.resource.data.createdAt == request.time;

      // 수정·삭제: 모두 차단
      allow update, delete: if false;
    }

    // 그 외 모든 문서: 기본 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
